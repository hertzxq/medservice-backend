{
    email {$ACME_EMAIL}
}

# TLS-терминация API на самом бэкенд-сервере: между серверами только публичная
# сеть, поэтому API_DOMAIN указывает DNS-ом прямо сюда, а порт 8000 наружу не
# публикуется вовсе — снаружи только 80/443 этого Caddy.
{$API_DOMAIN} {
    encode zstd gzip
    reverse_proxy backend:8000
}
