# MedService Backend — production environment
# Скопируй этот файл в .env и заполни значения.
# Никогда не коммить .env в git.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="MedService Feedback API"
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
GUNICORN_WORKERS=2

# ── PostgreSQL (контейнер postgres из docker-compose.prod.yml) ───────────────
POSTGRES_USER=medservice_user
# Сгенерируй: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD
POSTGRES_DB=medservice_db

# DATABASE_URL должен ссылаться на host=postgres (имя сервиса в docker-compose).
# Пароль должен совпадать с POSTGRES_PASSWORD выше.
DATABASE_URL=postgresql://medservice_user:REPLACE_ME_WITH_STRONG_PASSWORD@postgres:5432/medservice_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерируй: openssl rand -hex 32
SECRET_KEY=REPLACE_ME_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.fdbck.ru
