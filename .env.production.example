# MedService Backend — production environment
# Скопируй этот файл в .env и заполни значения.
# Никогда не коммить .env в git.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="MedService Feedback API"
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Домен API: DNS A-запись должна указывать на ЭТОТ сервер (бэкенд). TLS
# терминирует локальный caddy из docker-compose.prod.yml; порт 8000 наружу
# не публикуется. ACME_EMAIL — реальный адрес для Let's Encrypt.
API_DOMAIN=api.example.com
ACME_EMAIL=ops@example.com
# ВАЖНО: пока статус/блокировка парсинга хранятся в памяти процесса, держи 1
# воркер — иначе «парсинг уже запущен» и /parsing/status работают некорректно
# при нескольких воркерах. Поднимай только после переноса состояния в БД/Redis.
GUNICORN_WORKERS=1

# Интервал планировщика проверки отзывов (сервис verify), сек. По умолчанию 30 мин.
# Скрейпит только филиалы с pending-заявками — чтобы открыть шлюз верификации.
VERIFY_INTERVAL_SECONDS=1800

# Интервал полного обновления аналитики (сервис refresh), сек. По умолчанию сутки.
# Перепарсивает ВСЕ филиалы с площадками, чтобы цифры дашборда (новые/всего
# отзывов, рейтинг) не застаивались у филиалов без заявок. Скрейп тяжёлый —
# держи реже, чем VERIFY_INTERVAL_SECONDS.
REFRESH_INTERVAL_SECONDS=86400

# ── Bootstrap-админ (scripts/create_admin.py) ────────────────────────────────
# Первый суперпользователь создаётся НЕ через seed.py (он запрещён в проде), а
# командой `python scripts/create_admin.py` (см. DEPLOY.md). Можно задать здесь:
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_ME_WITH_STRONG_ADMIN_PASSWORD

# ── PostgreSQL (контейнер postgres из docker-compose.prod.yml) ───────────────
POSTGRES_USER=medservice_user
# Сгенерируй: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD
POSTGRES_DB=medservice_db

# DATABASE_URL должен ссылаться на host=postgres (имя сервиса в docker-compose).
# Пароль должен совпадать с POSTGRES_PASSWORD выше.
DATABASE_URL=postgresql://medservice_user:REPLACE_ME_WITH_STRONG_PASSWORD@postgres:5432/medservice_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Сгенерируй: openssl rand -hex 32
SECRET_KEY=REPLACE_ME_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Список через запятую. Добавь сюда домен mini-приложения (см. MINI_PUBLIC_URL),
# иначе браузерные запросы пациента из mini будут заблокированы CORS.
CORS_ORIGINS=https://app.fdbck.ru,https://REPLACE_WITH_MINI_DOMAIN

# ── SMS (sms.ru) ─────────────────────────────────────────────────────────────
# Без этих переменных бэкенд берёт дефолты из app/config.py:
#   SMS_TEST_MODE=True  → sms.ru только валидирует, реальные SMS НЕ уходят;
#   MINI_PUBLIC_URL=http://localhost:5173 → ссылки в SMS ведут на localhost.
# В проде это значит «отзывные SMS молча не работают». Обязательно задай:
SMS_RU_API_ID=REPLACE_ME_WITH_SMS_RU_API_ID
SMS_TEST_MODE=False
# Имя отправителя (одобренный в sms.ru sender). Пусто = sms.ru шлёт от своего имени.
SMS_SENDER=
# Публичный URL mini-приложения — основа ссылок «оставьте отзыв» в SMS.
MINI_PUBLIC_URL=https://REPLACE_WITH_MINI_DOMAIN
