# Application
APP_NAME="MedService Feedback API"
DEBUG=False
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL в Docker)
DATABASE_URL=postgresql://medservice_user:securepassword123@localhost:5432/medservice_db

# Security (⚠️ Изменить SECRET_KEY в production!)
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
FRONTEND_PUBLIC_URL=http://localhost:3000

# CORS (Frontend URL)
CORS_ORIGINS=http://localhost:3000,https://medservice.com

# Logging
LOG_LEVEL=INFO

# Email (Unisender)
UNISENDER_API_KEY=REPLACE_ME_WITH_UNISENDER_API_KEY
UNISENDER_SENDER_EMAIL=verified-sender@example.com
UNISENDER_SENDER_NAME=MedService
UNISENDER_LIST_ID=REPLACE_ME_WITH_UNISENDER_LIST_ID
